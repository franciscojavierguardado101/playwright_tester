<div class="pgt-wrap">

  {# ── LEFT PANEL ── #}
  <div class="pgt-left">
    <div class="pgt-hero">
      <div class="pgt-hero__badge">Playwright Tester</div>
      <h1 class="pgt-hero__title">Francisco Guardado<br>Playwright Tester</h1>
      <p class="pgt-hero__sub">Upload a Playwright <code>.spec.js</code> file to parse and display its tests.</p>
    </div>

    <div class="pgt-dropzone" id="pgt-dropzone">
      <div class="pgt-dropzone__inner">
        <div class="pgt-dropzone__icon">📄</div>
        <div class="pgt-dropzone__text">Drag & drop a <strong>.spec.js</strong> file here</div>
        <div class="pgt-dropzone__or">or</div>
        <label class="pgt-btn pgt-btn--upload" for="pgt-file-input">Choose File</label>
        <input type="file" id="pgt-file-input" accept=".js,.spec.js" style="display:none">
      </div>
    </div>

    <div class="pgt-file-bar" id="pgt-file-bar" style="display:none">
      <span class="pgt-file-bar__name" id="pgt-file-name"></span>
      <button class="pgt-btn pgt-btn--clear" id="pgt-clear">✕ Clear</button>
    </div>

    <div class="pgt-terminal" id="pgt-terminal" style="display:none">
      <div class="pgt-terminal__bar">
        <span class="pgt-terminal__dot pgt-terminal__dot--red"></span>
        <span class="pgt-terminal__dot pgt-terminal__dot--yellow"></span>
        <span class="pgt-terminal__dot pgt-terminal__dot--green"></span>
        <span class="pgt-terminal__bar-title" id="pgt-terminal-title">Tests</span>
      </div>
      <div class="pgt-terminal__body" id="pgt-terminal-body"></div>
      <div class="pgt-terminal__footer" id="pgt-terminal-footer"></div>
    </div>

    <div class="pgt-save-wrap" id="pgt-save-wrap" style="display:none">
      <button class="pgt-btn pgt-btn--save" id="pgt-save">💾 Save to Catalog</button>
      <span class="pgt-save-msg" id="pgt-save-msg"></span>
    </div>

  </div>

  {# ── RIGHT PANEL — CATALOG ── #}
  <div class="pgt-right">
    <div class="pgt-catalog-header">
      <h2 class="pgt-catalog-title">📋 Test Catalog</h2>
      <p class="pgt-catalog-sub">Previously uploaded spec files. Click any to view or reparse.</p>
    </div>

    <div class="pgt-catalog" id="pgt-catalog">
      {% if files is empty %}
        <div class="pgt-catalog__empty" id="pgt-catalog-empty">No files in the catalog yet. Upload your first spec file!</div>
      {% else %}
        {% for file in files %}
          <div class="pgt-catalog__item" data-id="{{ file.id }}">
            <div class="pgt-catalog__item-icon">📄</div>
            <div class="pgt-catalog__item-info">
              <div class="pgt-catalog__item-name">{{ file.filename }}</div>
              <div class="pgt-catalog__item-date">{{ file.created|date('M j, Y') }}</div>
            </div>
            <div class="pgt-catalog__item-actions">
              <button class="pgt-btn pgt-btn--view" data-id="{{ file.id }}">View</button>
              <button class="pgt-btn pgt-btn--download" data-id="{{ file.id }}" data-filename="{{ file.filename }}">⬇ Download</button>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

</div>
